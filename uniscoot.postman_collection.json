    {
      "name": "Admin - Rentals",
      "item": [
        {
          "name": "Cancel rental",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/rentals/{{rentalId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "rentals", "{{rentalId}}"]
            }
          }
        }
      ]
    }
  ]
}
