        {
          "name": "Delete zone",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/zones/{{zoneId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "zones", "{{zoneId}}"]
            }
          }
        }
      ]
    },
